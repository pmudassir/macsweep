<UserControl x:Class="WinSweep.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinSweep.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource BackgroundBrush}">
        <StackPanel Margin="32,28" MaxWidth="820">

            <!-- Page header -->
            <TextBlock Text="Dashboard"
                       Style="{StaticResource LargeTitleStyle}"/>
            <TextBlock Text="Overview of your system disk and available cleanup operations."
                       Style="{StaticResource BodyStyle}"
                       Margin="0,4,0,24"/>

            <!-- ── Disk usage hero card ──────────────────────────────────── -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SYSTEM DISK (C:)"
                                   Style="{StaticResource OverlineStyle}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding DiskFreeSpace}"
                                   Style="{StaticResource MetricLargeStyle}"/>
                        <TextBlock Text="available free space"
                                   Style="{StaticResource BodyStyle}"
                                   Margin="0,4,0,16"/>

                        <ProgressBar Value="{Binding DiskUsedPercent}"
                                     Minimum="0" Maximum="100"
                                     Style="{StaticResource AccentProgressBarStyle}"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="USED" Style="{StaticResource OverlineStyle}"/>
                                <TextBlock Text="{Binding DiskUsedDisplay}"
                                           Style="{StaticResource HeadingStyle}"
                                           Foreground="{StaticResource AccentPurpleBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="TOTAL" Style="{StaticResource OverlineStyle}"/>
                                <TextBlock Text="{Binding DiskTotalSpace}"
                                           Style="{StaticResource HeadingStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Percent circle indicator -->
                    <Border Grid.Column="1" Width="84" Height="84" Margin="20,0,0,0"
                            CornerRadius="42"
                            Background="{StaticResource AccentPurpleSubtleBrush}"
                            BorderBrush="{StaticResource AccentPurpleBrush}"
                            BorderThickness="2"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding DiskUsedPercentDisplay}"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource AccentPurpleBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Quick-action cards row ────────────────────────────────── -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Junk Cleaner card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18">
                    <StackPanel>
                        <TextBlock Text="&#xE74D;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{StaticResource AccentTealBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="JUNK FILES"
                                   Style="{StaticResource OverlineStyle}"/>
                        <TextBlock Text="Temp file scanner"
                                   Style="{StaticResource HeadingStyle}" FontSize="13"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Clears %TEMP% and LocalAppData\Temp"
                                   Style="{StaticResource CaptionStyle}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Cache Cleaner card -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18">
                    <StackPanel>
                        <TextBlock Text="&#xE968;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{StaticResource AccentPurpleBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="CACHE CLEANER"
                                   Style="{StaticResource OverlineStyle}"/>
                        <TextBlock Text="Browser &amp; system caches"
                                   Style="{StaticResource HeadingStyle}" FontSize="13"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Chrome, Edge, Firefox, DNS, thumbnails"
                                   Style="{StaticResource CaptionStyle}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Startup Manager card -->
                <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="18">
                    <StackPanel>
                        <TextBlock Text="&#xE7FC;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{StaticResource WarningBrush}"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="STARTUP MANAGER"
                                   Style="{StaticResource OverlineStyle}"/>
                        <TextBlock Text="Login-item control"
                                   Style="{StaticResource HeadingStyle}" FontSize="13"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Registry, startup folders, Task Scheduler"
                                   Style="{StaticResource CaptionStyle}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Info banner ───────────────────────────────────────────── -->
            <Border Background="{StaticResource AccentPurpleSubtleBrush}"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14">
                <DockPanel>
                    <TextBlock Text="&#xE946;"
                               FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="{StaticResource AccentPurpleBrush}"
                               VerticalAlignment="Top"
                               Margin="0,0,14,0"/>
                    <StackPanel>
                        <TextBlock Text="All destructive operations require your confirmation and are logged."
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Log file: %LOCALAPPDATA%\WinSweep\Logs\cleaner.log"
                                   Style="{StaticResource CaptionStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
