<Window x:Class="WinSweep.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinSweep — Windows System Cleaner"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR ════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>

                <!-- Logo area -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,16">
                    <StackPanel>
                        <TextBlock Text="WinSweep"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="System Cleaner  ·  v1.0"
                                   Style="{StaticResource CaptionStyle}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Divider -->
                <Rectangle DockPanel.Dock="Top" Height="1"
                           Fill="{StaticResource AppBorderBrush}" Margin="16,0"/>

                <!-- Bottom: log + version -->
                <Border DockPanel.Dock="Bottom" Padding="16,12">
                    <Button x:Name="BtnOpenLog"
                            Content="View Operation Log"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="11" Padding="12,6"
                            Click="BtnOpenLog_Click"/>
                </Border>

                <Rectangle DockPanel.Dock="Bottom" Height="1"
                           Fill="{StaticResource AppBorderBrush}" Margin="16,0"/>

                <!-- Navigation items -->
                <StackPanel Margin="0,16">
                    <RadioButton x:Name="NavDashboard"
                                 Tag="&#xE80F;"
                                 Content="Dashboard"
                                 Style="{StaticResource NavItemStyle}"
                                 GroupName="MainNav"
                                 IsChecked="True"
                                 Checked="NavDashboard_Checked"/>

                    <TextBlock Text="CLEANING"
                               Style="{StaticResource OverlineStyle}"
                               Margin="20,18,0,6"/>

                    <RadioButton x:Name="NavJunk"
                                 Tag="&#xE74D;"
                                 Content="Junk Cleaner"
                                 Style="{StaticResource NavItemStyle}"
                                 GroupName="MainNav"
                                 Checked="NavJunk_Checked"/>

                    <RadioButton x:Name="NavCache"
                                 Tag="&#xE968;"
                                 Content="Cache Cleaner"
                                 Style="{StaticResource NavItemStyle}"
                                 GroupName="MainNav"
                                 Checked="NavCache_Checked"/>

                    <TextBlock Text="SYSTEM"
                               Style="{StaticResource OverlineStyle}"
                               Margin="20,18,0,6"/>

                    <RadioButton x:Name="NavStartup"
                                 Tag="&#xE7FC;"
                                 Content="Startup Manager"
                                 Style="{StaticResource NavItemStyle}"
                                 GroupName="MainNav"
                                 Checked="NavStartup_Checked"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Sidebar/content divider line -->
        <Rectangle Grid.Column="1" Fill="{StaticResource AppBorderBrush}"/>

        <!-- ═══ MAIN CONTENT ════════════════════════════════════════════════ -->
        <Border Grid.Column="2" Background="{StaticResource BackgroundBrush}">
            <ContentControl x:Name="MainContent"/>
        </Border>

    </Grid>
</Window>
