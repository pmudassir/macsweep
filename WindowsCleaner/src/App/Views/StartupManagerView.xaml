<UserControl x:Class="WinSweep.Views.StartupManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinSweep.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:StartupManagerViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- info banner -->
            <RowDefinition Height="Auto"/>   <!-- column header row -->
            <RowDefinition Height="*"/>      <!-- entry list -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="28,22,24,18"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Startup Manager"
                               Style="{StaticResource LargeTitleStyle}"/>
                    <TextBlock Text="Manage apps that launch automatically when Windows starts."
                               Style="{StaticResource BodyStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Warning banner ─────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource WarningSubtleBrush}"
                BorderBrush="{StaticResource WarningBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,10">
            <DockPanel>
                <TextBlock Text="&#xE7BA;"
                           FontFamily="Segoe MDL2 Assets" FontSize="16"
                           Foreground="{StaticResource WarningBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBlock Text="System-critical entries (Windows Defender, WMI, etc.) are locked and cannot be modified."
                           FontFamily="Segoe UI Variable Small, Segoe UI"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource WarningBrush}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ── Column headers ─────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="NAME"      Style="{StaticResource OverlineStyle}"/>
                <TextBlock Grid.Column="1" Text="PUBLISHER" Style="{StaticResource OverlineStyle}"/>
                <TextBlock Grid.Column="2" Text="PATH"      Style="{StaticResource OverlineStyle}"/>
                <TextBlock Grid.Column="3" Text="SOURCE"    Style="{StaticResource OverlineStyle}"/>
                <TextBlock Grid.Column="4" Text="ENABLED"   Style="{StaticResource OverlineStyle}"/>
                <TextBlock Grid.Column="5" Text="ACTION"    Style="{StaticResource OverlineStyle}"/>
            </Grid>
        </Border>

        <!-- ── Startup entry list ─────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <!-- Loading overlay -->
            <Grid>
                <TextBlock Text="Click Refresh to load startup items."
                           Style="{StaticResource BodyStyle}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding IsLoading,
                               Converter={StaticResource BoolToVisConverter}}"/>

                <ItemsControl ItemsSource="{Binding Entries}"
                              Padding="16,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8,3" Padding="16,11"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontFamily="Segoe UI Variable, Segoe UI"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding Name}"/>

                                    <!-- Publisher -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Publisher}"
                                               Style="{StaticResource BodyStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="8,0"
                                               ToolTip="{Binding Publisher}"/>

                                    <!-- Path -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ExecutablePath}"
                                               Style="{StaticResource CaptionStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="8,0"
                                               ToolTip="{Binding ExecutablePath}"/>

                                    <!-- Source badge -->
                                    <Border Grid.Column="3"
                                            CornerRadius="4" Padding="6,3"
                                            Background="{StaticResource AccentPurpleSubtleBrush}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SourceDisplayName}"
                                                   FontFamily="Segoe UI Variable Small, Segoe UI"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentPurpleLightBrush}"/>
                                    </Border>

                                    <!-- Enable/Disable toggle -->
                                    <CheckBox Grid.Column="4"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                              IsEnabled="{Binding IsSystemCritical,
                                                  Converter={StaticResource BoolNegateConverter}}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Tag="{Binding}"
                                              Click="Toggle_Click"/>

                                    <!-- Delete button -->
                                    <Button Grid.Column="5"
                                            Content="Remove"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Padding="8,4" FontSize="11"
                                            IsEnabled="{Binding IsSystemCritical,
                                                Converter={StaticResource BoolNegateConverter}}"
                                            Tag="{Binding}"
                                            Click="Delete_Click"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="4"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <TextBlock Text="{Binding StatusText}"
                       Style="{StaticResource BodyStyle}"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
