<Application x:Class="WinSweep.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WinSweep.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Theme.xaml"/>
                <ResourceDictionary Source="Styles/ControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters (no third-party dependency) -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
            <conv:BoolToSafeTextConverter   x:Key="BoolToSafeConverter"/>
            <conv:BoolNegateConverter       x:Key="BoolNegateConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
